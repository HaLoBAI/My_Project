# 后端环境变量配置示例
# Docker Compose使用

# MySQL配置
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=hair_accessory_db
MYSQL_USER=hair_app
MYSQL_PASSWORD=hair_app_pass

# Redis配置
REDIS_PASSWORD=redis123456

# MinIO配置
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123456
MINIO_BUCKET_NAME=hair-accessory-images

# AI API配置（根据实际使用的服务填写）
AI_API_KEY=your_ai_api_key_here
AI_API_ENDPOINT=https://api.example.com/v1

# JWT配置
JWT_SECRET=your_very_long_secret_key_min_256_bits
JWT_EXPIRATION=604800 # 7 days in seconds

# 应用配置
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080

# 日志级别
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=DEBUG

# 文件上传限制
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=50MB

# 邮件配置（可选）
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your_email@gmail.com
# SPRING_MAIL_PASSWORD=your_app_password
