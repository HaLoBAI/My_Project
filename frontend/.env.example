# 前端环境变量配置示例
# 复制此文件为 .env.development 或 .env.production 并填写实际值

# API基础URL
VITE_API_BASE_URL=http://localhost:8080

# MinIO/CDN地址
VITE_MINIO_ENDPOINT=http://localhost:9000

# AI服务配置（如需前端直接调用）
# VITE_AI_API_KEY=your_ai_api_key_here

# 上传配置
VITE_MAX_UPLOAD_SIZE=5242880 # 5MB in bytes
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# 功能开关
VITE_ENABLE_OZON_INTEGRATION=true
VITE_ENABLE_ANALYTICS=false

# 第三方服务
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_GA_TRACKING_ID=your_ga_tracking_id_here
